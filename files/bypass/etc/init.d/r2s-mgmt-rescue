#!/bin/sh /etc/rc.common
# Ensure bypass management IP is reachable after a keep-config sysupgrade.
# If network.lan is missing/broken (no IPv4 on br-lan/eth0), force the
# known bypass defaults so the box can be reached at 10.11.11.3 again.

START=99
STOP=10

MGMT_IP='10.11.11.3'
MGMT_MASK='255.255.255.0'
MGMT_GW='10.11.11.1'
MGMT_DNS1='10.11.11.1'
MGMT_DNS2='119.29.29.29'
MARKER='/etc/r2s-mgmt-rescue.last'

log_msg() {
	logger -t r2s-mgmt-rescue "$@"
	echo "r2s-mgmt-rescue: $*" >/dev/kmsg 2>/dev/null || true
	[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log event rescue-msg "$*" 2>/dev/null || true
}

has_mgmt_ip() {
	ip -4 -o addr show dev br-lan 2>/dev/null | grep -q "inet ${MGMT_IP}/" && return 0
	ip -4 -o addr show dev eth0 2>/dev/null | grep -q "inet ${MGMT_IP}/" && return 0
	return 1
}

lan_has_any_ipv4() {
	ip -4 -o addr show dev br-lan 2>/dev/null | grep -q ' inet ' && return 0
	ip -4 -o addr show dev eth0 2>/dev/null | grep -q ' inet ' && return 0
	return 1
}

apply_bypass_lan() {
	local uplink_if='eth0'
	local unused_if='eth1'

	[ -e /sys/class/net/eth0 ] || {
		if [ -e /sys/class/net/end0 ]; then
			uplink_if='end0'
		elif [ -e /sys/class/net/eth1 ]; then
			uplink_if='eth1'
			unused_if='eth0'
		fi
	}

	uci -q get network.lan >/dev/null || uci set network.lan='interface'

	# Ensure br-lan exists and carries the native uplink NIC.
	if ! uci -q get network.@device[0] >/dev/null; then
		uci add network device >/dev/null
	fi
	# Prefer editing existing br-lan device section if present.
	local idx=0 found=''
	while uci -q get "network.@device[$idx]" >/dev/null; do
		if [ "$(uci -q get network.@device[$idx].name)" = 'br-lan' ]; then
			found="@device[$idx]"
			break
		fi
		idx=$((idx + 1))
	done
	if [ -z "$found" ]; then
		uci add network device >/dev/null
		found='@device[-1]'
		uci set "network.${found}.name=br-lan"
	fi
	uci set "network.${found}.type=bridge"
	uci -q delete "network.${found}.ports"
	uci add_list "network.${found}.ports=${uplink_if}"

	uci set network.lan.device='br-lan'
	uci set network.lan.proto='static'
	uci set network.lan.ipaddr="$MGMT_IP"
	uci set network.lan.netmask="$MGMT_MASK"
	uci set network.lan.gateway="$MGMT_GW"
	uci set network.lan.delegate='0'
	uci -q delete network.lan.dns
	uci add_list network.lan.dns="$MGMT_DNS1"
	uci add_list network.lan.dns="$MGMT_DNS2"

	if uci -q get network.wan >/dev/null; then
		uci set network.wan.device="$unused_if"
		uci set network.wan.proto='none'
		uci set network.wan.disabled='1'
	fi
	if uci -q get network.wan6 >/dev/null; then
		uci set network.wan6.device="$unused_if"
		uci set network.wan6.proto='none'
		uci set network.wan6.disabled='1'
	fi

	if uci -q get dhcp.lan >/dev/null; then
		uci set dhcp.lan.ignore='1'
		uci set dhcp.lan.dhcpv4='disabled'
		uci set dhcp.lan.dhcpv6='disabled'
		uci set dhcp.lan.ra='disabled'
	fi

	uci commit network
	uci commit dhcp 2>/dev/null || true
	/etc/init.d/network reload >/dev/null 2>&1 || /etc/init.d/network restart >/dev/null 2>&1 || true
}

boot() {
	start
}

start() {
	# Only act on bypass images (marker written by 99-bypass-router).
	if [ "$(uci -q get system.@system[0].r2s_bypass_defaults)" != '1' ]; then
		# Still rescue if this is clearly a broken keep-config boot: no IPv4 at all
		# on lan after network is up, and eth0 exists (R2S).
		[ -e /sys/class/net/eth0 ] || return 0
	fi

	# Wait for netifd to settle a bit.
	local i=0
	while [ "$i" -lt 20 ]; do
		if has_mgmt_ip; then
			[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log event boot-ok "mgmt ip present" 2>/dev/null || true
			return 0
		fi
		# If lan already has some other IPv4, do not override user choice.
		if lan_has_any_ipv4; then
			[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log event boot-ok "lan has non-default ipv4" 2>/dev/null || true
			return 0
		fi
		sleep 1
		i=$((i + 1))
	done

	if has_mgmt_ip || lan_has_any_ipv4; then
		return 0
	fi

	log_msg "lan has no IPv4 after boot; applying bypass management defaults (${MGMT_IP})"
	date '+%F %T' >"$MARKER" 2>/dev/null || true
	[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log rescue "no lan ipv4; applying ${MGMT_IP}" 2>/dev/null || true
	apply_bypass_lan

	# Final live address inject if UCI reload still left us unreachable.
	sleep 2
	if ! has_mgmt_ip && ! lan_has_any_ipv4; then
		if [ -e /sys/class/net/br-lan ]; then
			ip addr add "${MGMT_IP}/24" dev br-lan 2>/dev/null || true
			ip link set br-lan up 2>/dev/null || true
		elif [ -e /sys/class/net/eth0 ]; then
			ip addr add "${MGMT_IP}/24" dev eth0 2>/dev/null || true
			ip link set eth0 up 2>/dev/null || true
		fi
		ip route replace default via "$MGMT_GW" 2>/dev/null || true
		log_msg "injected live address ${MGMT_IP}/24"
		[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log rescue "live inject ${MGMT_IP}/24" 2>/dev/null || true
	fi

	# Capture post-rescue network state for offline analysis.
	[ -x /usr/sbin/r2s-upgrade-log ] && /usr/sbin/r2s-upgrade-log snapshot post-rescue 2>/dev/null || true
}

stop() {
	return 0
}
